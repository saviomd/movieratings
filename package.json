{
  "name": "movieratings",
  "private": true,
  "version": "1.20260709.0",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "npx prettier . --write",
    "lint": "eslint .",
    "lint:config-inspector": "npx @eslint/config-inspector@latest",
    "lint:fix": "eslint . --fix",
    "postbuild": "mv build/client/$npm_package_name/* build/client/ && rm -rf build/client/$npm_package_name && cp build/client/index.html build/client/404.html",
    "prepare": "husky",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "build-storybook": "STORYBOOK=true storybook build -o build/client/storybook"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@react-router/node": "^8.2.0",
    "@react-router/serve": "^8.2.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.8",
    "isbot": "^5.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-ga4": "^3.0.1",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@react-router/dev": "^8.2.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}
